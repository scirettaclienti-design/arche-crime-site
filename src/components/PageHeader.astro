---
import Ornament from './Ornament.astro';

interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  align?: 'center' | 'left';
}

const { eyebrow, title, intro, align = 'center' } = Astro.props;

const alignment = align === 'center' ? 'text-center' : 'text-left';
const wrap = align === 'center' ? 'mx-auto max-w-text' : 'max-w-text';
---

<header class={`${wrap} px-6 pt-24 pb-12 sm:pt-32 sm:pb-16 ${alignment}`}>
  <p class="mb-8 text-xs uppercase tracking-eyebrow text-gold-bright">
    {eyebrow}
  </p>
  <h1 class="font-display text-4xl leading-tight text-bone sm:text-5xl md:text-6xl">
    {title}
  </h1>
  {
    intro && (
      <>
        <Ornament class="mt-12" />
        <p class="mt-12 font-serif text-lg leading-loose text-bone-dim sm:text-xl">
          {intro}
        </p>
      </>
    )
  }
</header>
