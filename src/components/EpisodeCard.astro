---
interface Props {
  numero: number | string;
  titolo: string;
  mito: string;
  fenomeno: string;
  slug: string;
  fonte?: string;
  durata?: string;
  estratto?: string;
  variant?: 'feature' | 'compact';
}

const {
  numero,
  titolo,
  mito,
  fenomeno,
  slug,
  fonte,
  durata,
  estratto,
  variant = 'compact',
} = Astro.props;

const href = `/episodi/${slug}`;
const numeroPadded = typeof numero === 'number'
  ? String(numero).padStart(2, '0')
  : numero;

const isFeature = variant === 'feature';
---

<article
  class:list={[
    'group relative border border-[var(--line-soft)] bg-ink-2 transition-colors duration-medium ease-out-quart hover:border-[var(--line)]',
    isFeature ? 'p-8 sm:p-12' : 'p-6 sm:p-8',
  ]}
>
  <a
    href={href}
    class="absolute inset-0 z-10"
    aria-label={`Apri l'episodio ${numeroPadded} — ${titolo}`}
  ></a>

  <div class="flex items-center gap-3 text-xs uppercase tracking-eyebrow text-gold-bright">
    <span>Episodio {numeroPadded}</span>
    {durata && (
      <>
        <span class="text-bone-faint">·</span>
        <span class="text-bone-faint">{durata}</span>
      </>
    )}
  </div>

  <h2
    class:list={[
      'mt-4 font-display leading-tight text-bone transition-colors group-hover:text-gold-bright',
      isFeature ? 'text-3xl sm:text-4xl md:text-5xl' : 'text-2xl sm:text-3xl',
    ]}
  >
    {titolo}
  </h2>

  <p class="mt-4 text-sm text-bone-dim">
    <span class="font-display italic text-bone">{mito}</span>
    <span class="text-bone-faint"> — </span>
    <span>{fenomeno}</span>
  </p>

  {
    estratto && (
      <p class:list={[
        'mt-6 max-w-text font-serif text-bone-dim',
        isFeature ? 'text-lg leading-loose' : 'text-base leading-loose',
      ]}>
        {estratto}
      </p>
    )
  }

  <div class="mt-8 flex items-center justify-between gap-4 border-t border-[var(--line-soft)] pt-6">
    {
      fonte ? (
        <p class="text-xs uppercase tracking-eyebrow text-bone-faint">
          fonte · {fonte}
        </p>
      ) : <span></span>
    }
    <span
      class="text-xs uppercase tracking-eyebrow text-gold-bright transition-colors group-hover:text-bone"
    >
      Vai all'episodio →
    </span>
  </div>
</article>
