---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MotionHead from '../components/motion/MotionHead.astro';
import EpigraphFilter from '../components/motion/EpigraphFilter.astro';
import SmoothScroll from '../components/motion/SmoothScroll';
import JsonLd from '../components/seo/JsonLd.astro';
import {
  orgSchema,
  websiteSchema,
  personSchema,
  breadcrumbSchema,
  buildBreadcrumb,
  ogImageUrl as buildOgImageUrl,
  SITE_NAME,
} from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Override completo dell'OG image (assoluto). Default: /og/{slug}.png auto. */
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'archè — dal mito alla mente. Una piattaforma editoriale sulla criminologia letta attraverso il mito greco, di Gabriella Marano.',
  ogImage,
  noindex = false,
} = Astro.props;

const fullTitle = title ? `${title} · ${SITE_NAME}` : `${SITE_NAME} · dal mito alla mente`;
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, Astro.site).toString();
const finalOgImage = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : buildOgImageUrl(pathname);

// Breadcrumb: append solo se siamo oltre la home (più di 1 item).
const breadcrumb = buildBreadcrumb(pathname);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />

    <link rel="canonical" href={canonical} />
    {/* hreflang self-referential: il sito è monolingua it-IT. Quando aggiungeremo
        eventuali altre lingue, andrà esteso con alternate per ogni locale. */}
    <link rel="alternate" hreflang="it-IT" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={finalOgImage} />

    <meta name="generator" content={Astro.generator} />

    {/* Favicon: rombo oro inline SVG, niente network. */}
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%2314110C'/%3E%3Cpath d='M16 6 L26 16 L16 26 L6 16 Z' fill='%23C8A24E'/%3E%3C/svg%3E"
    />

    {/* JSON-LD globali: Organization + WebSite + Person + (eventuale)
        BreadcrumbList per pagine interne. La home (path '/') ha breadcrumb
        a 1 voce sola → la omettiamo (non utile). */}
    <JsonLd data={orgSchema()} />
    <JsonLd data={websiteSchema()} />
    <JsonLd data={personSchema()} />
    {breadcrumb.length > 1 && <JsonLd data={breadcrumbSchema(breadcrumb)} />}

    {/* Slot per JSON-LD specifico di pagina (es. FAQPage su /metodo). */}
    <slot name="head" />

    <MotionHead />

    {/* Vercel Analytics: SOLO pageview, niente eventi custom, nessun cookie.
        Lo script è servito da Vercel in produzione; in locale 404 silenzioso. */}
    <script defer src="/_vercel/insights/script.js" is:inline></script>

    {/* Vercel Speed Insights — opzionale, aggiungibile in futuro. */}
  </head>
  <body class="bg-ink text-bone font-serif min-h-screen antialiased">
    <a class="skip-link" href="#main">Vai al contenuto</a>

    <EpigraphFilter />

    <Nav />

    <main id="main" class="relative z-10">
      <slot />
    </main>

    <Footer />

    <SmoothScroll client:load />
  </body>
</html>
