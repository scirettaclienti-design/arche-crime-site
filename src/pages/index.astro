---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import Ornament from '../components/Ornament.astro';
import VideoBackground from '../components/VideoBackground.astro';
import GreekMeander from '../components/motion/GreekMeander.astro';
import RevealText from '../components/motion/RevealText.astro';
import CurtainOpening from '../components/motion/CurtainOpening.astro';

export const prerender = true;

// "Ultimo episodio" — pesca dinamicamente l'episodio pubblicato più
// recente. Criterio di ordine:
//   1. dataPubblicazione (desc) se presente,
//   2. fallback: numero più alto.
// Quando non c'è ancora nessun episodio pubblicato → stato "in arrivo".
const episodiPubblicati = await getCollection('episodi', ({ data }) => data.pubblicato);
const ultimoEpisodio = episodiPubblicati.sort((a, b) => {
  const da = a.data.dataPubblicazione?.getTime() ?? 0;
  const db = b.data.dataPubblicazione?.getTime() ?? 0;
  if (db !== da) return db - da;
  return b.data.numero - a.data.numero;
})[0] ?? null;

const porte = [
  {
    eyebrow: 'Guarda',
    titolo: 'Gli episodi',
    descrizione:
      'Cinque tappe per ogni storia: archeologia, scena, decodifica, presente, restituzione. Senza fretta.',
    href: '/episodi',
  },
  {
    eyebrow: 'Ascolta',
    titolo: 'Dal vivo',
    descrizione:
      'archè è anche teatro e parola: tappe negli istituti, nei festival, nelle aule.',
    href: '/dal-vivo',
  },
  {
    eyebrow: 'Partecipa',
    titolo: 'La formazione',
    descrizione:
      'Masterclass, corsi e un libro: per chi vuole capire il metodo da dentro, non solo guardarlo.',
    href: '/formazione',
  },
];
---

<BaseLayout
  description="archè — dal mito alla mente. Una piattaforma editoriale di Gabriella Marano: criminologia letta attraverso il mito greco, senza cronaca nera."
>
  {/* HERO PIN — solo soglia.
      Outer 140vh (desktop) / 130vh (mobile): un pin breve che fa "respirare"
      il video pieno schermo per ~1.4 viewport prima di rilasciare. Niente
      crossfade di testi sopra il video: il video tiene SOLO la soglia
      (ἀρχή + meandro + h1). Manifesto e closing escono dopo il pin come
      momenti di SOLO TESTO, con respiro. */}
  <section
    data-hero-pin
    class="relative h-[130vh] overflow-visible sm:h-[140vh]"
  >
    <div
      data-hero-sticky
      class="sticky top-0 flex h-screen w-full items-center justify-center overflow-hidden"
    >
      <VideoBackground
        name="hero"
        overlayOpacity={0.7}
        overlayDirection="radial"
        objectPosition="center 22%"
        objectPositionMobile="center 18%"
        parallax={true}
        parallaxAmount={40}
        ariaLabel="Sfondo: una lucerna a olio si accende lentamente nel buio di un tempio greco"
      />

      {/* Doppio hero-glow oro (rinforza la fiamma) */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-[20vh] -z-[5] h-[40vh] w-[40vh] -translate-x-1/2 opacity-60"
        style="background: radial-gradient(circle, var(--color-gold-deep) 0%, transparent 65%); mix-blend-mode: screen; filter: blur(60px);"
      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-[28vh] -z-[5] h-[25vh] w-[25vh] -translate-x-1/2 opacity-50"
        style="background: radial-gradient(circle, var(--color-gold-bright) 0%, transparent 60%); mix-blend-mode: screen; filter: blur(80px);"
      >
      </div>

      {/* STAGE UNICA — THRESHOLD: ἀρχή + meandro + h1. */}
      <div
        data-hero-stage="threshold"
        class="absolute inset-0 z-10 flex flex-col items-center justify-center px-6 text-center"
      >
        <RevealText variant="fade" delay={0.2} class="mb-10">
          <p class="text-xs tracking-eyebrow text-gold-bright">
            <span class="greek font-display text-base italic text-gold-bright">ἀρχή</span>
            <span class="uppercase"> · origine</span>
          </p>
        </RevealText>

        <div class="mb-10">
          <GreekMeander
            modules={5}
            entrance="arrival"
            arrivalDelay={0.6}
            arrivalDuration={1.2}
            class="mx-auto max-w-md opacity-90"
          />
        </div>

        <CurtainOpening delay={1.6} duration={1.4}>
          <h1
            class="is-epigraph font-display text-5xl leading-tight text-bone sm:text-6xl md:text-7xl"
          >
            Dal mito<br />alla mente<span class="text-gold-bright">.</span>
          </h1>
        </CurtainOpening>

        <p
          data-hero-scroll-hint
          class="absolute bottom-10 left-1/2 -translate-x-1/2 text-xs uppercase tracking-eyebrow text-bone-faint opacity-0"
        >
          continua a scorrere ↓
        </p>
      </div>
    </div>
  </section>

  {/* MOMENTO TESTUALE 1 — Il manifesto, in solo testo dopo il pin.
      Generoso di respiro (py-32), max-w-text per concentrare la riga. */}
  <section class="relative bg-ink px-6 py-32 sm:py-40">
    <RevealText variant="fade" class="mx-auto block max-w-text text-center">
      <p class="font-serif text-xl leading-loose text-bone sm:text-2xl md:text-3xl">
        archè è la piattaforma editoriale di Gabriella Marano. Una lettura
        criminologica dei fenomeni umani che parte dal teatro greco — perché
        le storie che ci raccontiamo da duemilacinquecento anni dicono molto
        più della cronaca di ieri.
      </p>
    </RevealText>
  </section>

  {/* MOMENTO TESTUALE 2 — La dichiarazione. Più stretta, più dichiarativa.
      Su due righe per dare peso all'antitesi. */}
  <section class="relative bg-ink px-6 py-24 text-center sm:py-32">
    <RevealText variant="fade">
      <p class="font-display italic text-4xl leading-tight text-bone sm:text-5xl md:text-6xl">
        Non cronaca nera.
      </p>
      <p class="mt-4 font-display italic text-4xl leading-tight text-gold-bright sm:text-5xl md:text-6xl">
        Un metodo.
      </p>
    </RevealText>
  </section>

  <section class="mx-auto max-w-wide px-6 py-16 sm:py-20">
    {
      ultimoEpisodio ? (
        <>
          <RevealText variant="fade" class="mx-auto max-w-text text-center">
            <p class="mb-4 text-xs uppercase tracking-eyebrow text-gold-bright">
              Ultimo episodio
            </p>
            <h2 class="font-display text-2xl leading-tight text-bone sm:text-3xl">
              In apertura
            </h2>
          </RevealText>

          <RevealText variant="fade" delay={0.15} class="mx-auto mt-12 block max-w-3xl">
            <EpisodeCard
              variant="feature"
              numero={ultimoEpisodio.data.numero}
              slug={ultimoEpisodio.data.slug}
              titolo={ultimoEpisodio.data.titolo}
              mito={ultimoEpisodio.data.mito}
              fenomeno={ultimoEpisodio.data.fenomeno}
              fonte={ultimoEpisodio.data.fonte}
              durata={ultimoEpisodio.data.durata}
              estratto={ultimoEpisodio.data.estratto}
            />
          </RevealText>
        </>
      ) : (
        <RevealText variant="fade" class="mx-auto max-w-text text-center">
          <p class="mb-4 text-xs uppercase tracking-eyebrow text-gold-bright">
            archivio in apertura
          </p>
          <h2 class="font-display text-2xl italic leading-tight text-bone sm:text-3xl">
            Il primo episodio sta arrivando.
          </h2>
          <p class="mx-auto mt-8 max-w-text font-serif text-base leading-loose text-bone-dim">
            archè si apre con Medea. Lavoriamo lentamente — torna fra poco, oppure
            entra da
            <a class="text-gold-bright hover:text-bone" href="/metodo">
              Il metodo
            </a>
            mentre aspetti.
          </p>
        </RevealText>
      )
    }
  </section>

  <GreekMeander modules={6} scrub={0.6} class="my-16 px-6 opacity-80" />

  <section class="mx-auto max-w-wide px-6 py-20 sm:py-24">
    <RevealText variant="fade" class="mx-auto max-w-text text-center">
      <p class="mb-6 text-xs uppercase tracking-eyebrow text-gold-bright">
        Le tre porte
      </p>
      <h2 class="font-display text-3xl leading-tight text-bone sm:text-4xl">
        Da dove si entra
      </h2>
      <p class="mt-6 font-serif text-base leading-loose text-bone-dim">
        archè non è un canale, è una soglia. Tre modi diversi di attraversarla.
      </p>
    </RevealText>

    <ul class="mt-16 grid grid-cols-1 gap-px overflow-hidden border border-[var(--line-soft)] bg-[var(--line-soft)] md:grid-cols-3">
      {
        porte.map((porta, i) => (
          <li class="bg-ink-2">
            <RevealText variant="fade" delay={0.1 * i} class="block h-full">
              <a
                href={porta.href}
                class="group block h-full p-8 transition-colors duration-medium ease-out-quart hover:bg-ink-3 sm:p-10"
              >
                <p class="text-xs uppercase tracking-eyebrow text-gold-bright">
                  {porta.eyebrow}
                </p>
                <h3 class="mt-4 font-display text-2xl leading-tight text-bone transition-colors group-hover:text-gold-bright sm:text-3xl">
                  {porta.titolo}
                </h3>
                <p class="mt-5 font-serif text-base leading-loose text-bone-dim">
                  {porta.descrizione}
                </p>
                <p class="mt-8 text-xs uppercase tracking-eyebrow text-gold-bright transition-colors group-hover:text-bone">
                  Entra →
                </p>
              </a>
            </RevealText>
          </li>
        ))
      }
    </ul>
  </section>

  <GreekMeander modules={4} scrub={0.7} class="my-12 px-6 opacity-70" showKnot={true} color="var(--color-patina-bright)" />

  <section class="mx-auto max-w-text px-6 pb-24 text-center">
    <RevealText variant="fade">
      <Ornament size="sm" class="mb-6" />
      <p class="font-display italic text-base text-bone-faint sm:text-lg">
        <span class="greek">ἀρχή</span> — l'origine, il principio, ciò da cui tutto discende.
      </p>
    </RevealText>
  </section>
</BaseLayout>
