---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout
  description="archè — dal mito alla mente. Criminologia letta attraverso il mito greco, di Gabriella Marano."
>
  <section class="mx-auto max-w-text px-6 py-32 text-center sm:py-40">
    <p class="mb-8 text-xs uppercase tracking-eyebrow text-gold-bright">
      archè
    </p>
    <h1 class="mb-8 font-display text-5xl leading-tight text-bone sm:text-7xl">
      archè<span class="text-gold-bright"> ◆</span>
    </h1>
    <p class="font-display text-xl italic text-bone-dim sm:text-2xl">
      dal mito alla mente
    </p>
  </section>
</BaseLayout>
