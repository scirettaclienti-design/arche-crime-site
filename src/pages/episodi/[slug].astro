---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Ornament from '../../components/Ornament.astro';

export const prerender = true;

export async function getStaticPaths() {
  const episodi = await getCollection('episodi', ({ data }) => data.pubblicato);
  return episodi.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'episodi'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const ep = entry.data;
const numeroPadded = String(ep.numero).padStart(2, '0');

// Le 5 tappe del format archè — struttura visibile/ancore.
// Ogni episodio passa per queste cinque stazioni, sempre nello stesso ordine.
const tappe = [
  {
    id: 'apertura-archeologica',
    n: 'I',
    titolo: 'Apertura archeologica',
    nota: 'Da dove viene questa storia: il testo classico, il mito, la prima scena.',
  },
  {
    id: 'la-scena',
    n: 'II',
    titolo: 'La scena',
    nota: 'Cosa accade in tragedia. La descrizione del gesto, prima di nominarlo con la lingua di oggi.',
  },
  {
    id: 'decodifica-criminologica',
    n: 'III',
    titolo: 'Decodifica criminologica',
    nota: 'Il fenomeno reale che il mito stava già nominando. Senza diagnosi su persone esistenti.',
  },
  {
    id: 'il-presente',
    n: 'IV',
    titolo: 'Il presente',
    nota: 'Come questo fenomeno vive oggi: dati, ricerca, vocabolario degli operatori.',
  },
  {
    id: 'restituzione',
    n: 'V',
    titolo: 'Restituzione',
    nota: 'Cosa portare via. Una lente, non una sentenza.',
  },
];
---

<BaseLayout
  title={`Ep. ${numeroPadded} — ${ep.titolo}`}
  description={ep.estratto}
>
  <article class="mx-auto max-w-text px-6 pt-20 pb-12 sm:pt-28">
    <header class="text-center">
      <p class="text-xs uppercase tracking-eyebrow text-gold-bright">
        Episodio {numeroPadded}
        {ep.durata && (
          <>
            <span class="text-bone-faint"> · </span>
            <span class="text-bone-faint">{ep.durata}</span>
          </>
        )}
      </p>
      <h1 class="mt-6 font-display text-4xl leading-tight text-bone sm:text-5xl md:text-6xl">
        {ep.titolo}
      </h1>
      <p class="mt-8 font-display text-lg italic text-bone-dim sm:text-xl">
        <span class="text-bone">{ep.mito}</span>
        <span class="text-bone-faint"> — </span>
        {ep.fenomeno}
      </p>
      <p class="mt-3 text-xs uppercase tracking-eyebrow text-bone-faint">
        fonte · {ep.fonte}
      </p>
    </header>

    <Ornament class="mt-12" />
  </article>

  <section class="mx-auto max-w-wide px-6 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      {/* TODO(blocco-mux): se ep.muxPlaybackId è presente, montare
         <mux-player> qui (web component) con playback-id e metadata.
         Per ora: solo riquadro estetico 16:9 con triangolo play. */}
      <div
        class="relative aspect-video overflow-hidden border border-[var(--line)] bg-ink-2"
        aria-label={`Player video — episodio ${numeroPadded} — ${ep.titolo}`}
      >
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="flex flex-col items-center gap-6 text-center">
            <span
              class="font-display text-5xl text-gold-bright sm:text-6xl"
              aria-hidden="true"
            >
              ▷
            </span>
            <p class="text-xs uppercase tracking-eyebrow text-bone-dim">
              {ep.muxPlaybackId ? 'video pronto · player in arrivo' : 'video in lavorazione'}
            </p>
          </div>
        </div>
        <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-[var(--line)]"></div>
      </div>
    </div>
  </section>

  {
    ep.capitoli && ep.capitoli.length > 0 && (
      <section class="mx-auto max-w-text px-6 py-12">
        <header>
          <p class="text-xs uppercase tracking-eyebrow text-gold-bright">
            Capitoli
          </p>
          <h2 class="mt-3 font-display text-2xl leading-tight text-bone sm:text-3xl">
            Indice dell'episodio
          </h2>
        </header>
        <ol class="mt-8 space-y-px overflow-hidden border border-[var(--line-soft)] bg-[var(--line-soft)]">
          {ep.capitoli.map((cap, i) => (
            <li class="flex items-baseline justify-between gap-6 bg-ink-2 px-6 py-4 sm:px-8 sm:py-5">
              <div class="flex items-baseline gap-4">
                <span class="font-display text-sm text-gold-bright sm:text-base">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="font-serif text-base text-bone">{cap.titolo}</span>
              </div>
              <span class="shrink-0 font-display text-xs tracking-base text-bone-faint sm:text-sm">
                {cap.timestamp}
              </span>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  <section
    class="prose-arche mx-auto max-w-text px-6 py-16 font-serif text-lg leading-loose text-bone-dim sm:py-20"
  >
    <Content />
  </section>

  <Ornament class="my-8" />

  <section class="mx-auto max-w-wide px-6 py-16 sm:py-20">
    <header class="mx-auto max-w-text text-center">
      <p class="mb-6 text-xs uppercase tracking-eyebrow text-gold-bright">
        Il format archè
      </p>
      <h2 data-vary class="font-display text-3xl leading-tight text-bone sm:text-4xl">
        Le cinque tappe
      </h2>
      <p class="mt-6 font-serif leading-loose text-bone-dim">
        Ogni episodio attraversa cinque stazioni, nello stesso ordine. Non è una
        scaletta: è il metodo, reso visibile.
      </p>
    </header>

    <ol class="mt-16 grid grid-cols-1 gap-px overflow-hidden border border-[var(--line-soft)] bg-[var(--line-soft)] md:grid-cols-2 lg:grid-cols-5">
      {
        tappe.map((tappa) => (
          <li class="bg-ink-2 p-6 sm:p-8">
            <a
              href={`#${tappa.id}`}
              class="block transition-colors hover:text-gold-bright"
            >
              <span class="font-display text-3xl text-gold-bright">
                {tappa.n}
              </span>
              <h3 class="mt-4 font-display text-lg leading-tight text-bone">
                {tappa.titolo}
              </h3>
              <p class="mt-3 text-sm leading-loose text-bone-dim">
                {tappa.nota}
              </p>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <Ornament class="my-12" />

  <section class="mx-auto max-w-text px-6 pb-24 text-center">
    <p class="text-xs uppercase tracking-eyebrow text-gold-bright">
      Continua l'archivio
    </p>
    <p class="mt-4 font-display text-lg italic text-bone-dim">
      Torna a tutti gli episodi
    </p>
    <a
      href="/episodi"
      class="mt-8 inline-block border border-[var(--line)] px-6 py-3 text-xs uppercase tracking-eyebrow text-bone transition-colors hover:border-gold-bright hover:text-gold-bright"
    >
      ← L'archivio
    </a>
  </section>
</BaseLayout>
